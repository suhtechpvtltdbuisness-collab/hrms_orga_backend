PORT=4000
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Employee face attendance (private OpenCV service)
FACE_RECOGNITION_SERVICE_URL=http://localhost:8000
FACE_RECOGNITION_SERVICE_KEY=replace-with-a-long-random-secret
# OpenCV SFace cosine threshold (recommended starting range: 0.40-0.50)
FACE_MATCH_THRESHOLD=0.42

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# SSO Cookie Configuration (production)
# Recommended: run the API on api.orga.cc (same parent domain as the frontends,
# ideally behind Cloudflare). This makes auth same-site and avoids the
# SameSite=None fragility + cloud-IP blocking that breaks some wifi networks.
COOKIE_DOMAIN=.orga.cc
COOKIE_SECURE=true
CORS_ORIGINS=https://orga.cc,https://www.orga.cc,https://admin.orga.cc

# Local development (uncomment for localhost SSO testing)
# COOKIE_DOMAIN=
# COOKIE_SECURE=false
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# Optional: Razorpay plan id for Growth tier (₹2,999/month after trial). Created automatically if omitted.
RAZORPAY_STARTER_PLAN_ID=

# Cookie SSO — only needed when the API is on a DIFFERENT parent domain than the
# frontends (e.g. *.up.railway.app or *.vercel.app). Prefer api.orga.cc above.
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true

# Google OAuth Configuration
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# Email
# Railway blocks outbound SMTP (ports 465/587). Use Resend in production.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@orga.cc
EMAIL_FROM_NAME=ORGA HRMS
DEMO_REQUEST_EMAIL=info@suhtech.top

# SMTP (local development only — does not work on Railway)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@orga.cc
SMTP_PASS=your_smtp_password
