PORT=4000
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# SSO Cookie Configuration (production)
COOKIE_DOMAIN=.suhtech.store
COOKIE_SECURE=true
CORS_ORIGINS=https://suhtech.store,https://admin.suhtech.store

# Local development (uncomment for localhost SSO testing)
# COOKIE_DOMAIN=
# COOKIE_SECURE=false
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# Optional: Razorpay plan id for Growth tier (₹2,999/month after trial). Created automatically if omitted.
RAZORPAY_STARTER_PLAN_ID=

# Cookie SSO — use when API is on a different domain than frontends (e.g. Vercel)
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true

# Production with api.suhtech.store (recommended):
# COOKIE_DOMAIN=.suhtech.store
# COOKIE_SECURE=true

# Google OAuth Configuration
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
